# .env.example — variables para `docker-compose up`
# Copia este archivo a `.env` (en esta misma carpeta) y rellena los valores.
# El `.env` está ignorado por git y NO debe commitearse.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=GENERAR_PASSWORD_FUERTE
POSTGRES_DB=especially_v1

# ── pgAdmin (panel web en localhost:8080) ────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=tu@correo.com
PGADMIN_DEFAULT_PASSWORD=GENERAR_PASSWORD_FUERTE
